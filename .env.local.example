# Next.js Configuration
NEXT_JS_SHOW_BOUNDARIES=false

# Add your environment variables below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/headstonesdesigner
# API_KEY=
# NEXT_PUBLIC_APP_URL=https://forevershining.org

SESSION_SECRET=change-this-to-a-long-random-secret-in-production

# Remote file storage (production) — deploy legacy/upload.php to wiecznapamiec.pl first
# Generate the secret with: openssl rand -hex 32
UPLOAD_REMOTE_URL=https://www.wiecznapamiec.pl/forevershining/upload.php
UPLOAD_REMOTE_SECRET=Q25^ECDjl3!1

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

