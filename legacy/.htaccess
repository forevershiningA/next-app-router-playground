# Place this file as: public_html/forevershining/uploads/.htaccess
# Adds CORS headers so Three.js (WebGL) can load textures from this directory.
# Images are public assets — wildcard origin is safe and avoids Apache version
# compatibility issues with conditional SetEnvIf/Header format strings.

<IfModule mod_headers.c>
    <FilesMatch "\.(png|jpg|jpeg|webp|gif)">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET"
    </FilesMatch>
</IfModule>
