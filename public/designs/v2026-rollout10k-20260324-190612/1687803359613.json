        "surface": "headstone/front"
      },
      {
        "id": "insc-10",
        "text": "When I am gone, and earth ticks on, In syncopated marathon,",
        "font": {
          "family": "Garamond",
          "size_px": 15
        },
        "position": {
          "x_px": 6.25,
