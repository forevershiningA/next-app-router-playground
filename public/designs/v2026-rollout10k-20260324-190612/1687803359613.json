          "z_deg": 0
        },
        "color": "#ffb35a",
        "surface": "headstone/front"
      },
      {
        "id": "insc-14",
        "text": "Look for me and hear my sigh, In quiet glade and wind-scaped sky,",
        "font": {
          "family": "Garamond",
          "size_px": 14
        },
        "position": {
          "x_px": -6.25,
          "y_px": -86.862
