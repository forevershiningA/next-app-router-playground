  "elements": {
    "inscriptions": [
      {
        "id": "insc-8",
        "text": "In dew-stain grass and morning mist, Leaf littered soil the frost has kissed.",
        "font": {
          "family": "Garamond",
          "size_px": 15
        },
        "position": {
