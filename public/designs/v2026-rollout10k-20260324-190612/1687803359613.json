          "z_deg": 0
        },
        "color": "#ffb35a",
        "surface": "headstone/front"
      },
      {
        "id": "insc-12",
        "text": "Remember when my soul was young, and life’s songs had not been sung.",
        "font": {
          "family": "Garamond",
          "size_px": 14
        },
        "position": {
          "x_px": 0,
          "y_px": -130.103
        },
