        "surface": "headstone/front"
      },
      {
        "id": "insc-19",
        "text": "HARLEY BECKER",
        "font": {
          "family": "Garamond",
          "size_mm": 23.857,
          "weight": 400
        },
        "position": {
          "x_mm": 167.541,
