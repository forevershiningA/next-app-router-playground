  "elements": {
    "inscriptions": [
      {
        "id": "insc-11",
        "text": "26 May, 1949 - 09 December, 2023",
        "font": {
          "family": "Garamond",
          "size_mm": 17.908,
          "weight": 400
        },
        "position": {
          "x_mm": 160.497,
          "y_mm": 33.141
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-12",
        "text": "May you rest in peace, our guardian angels.",
        "font": {
          "family": "Lucida Calligraphy",
          "size_mm": 16.059,
          "weight": 400
        },
        "position": {
          "x_mm": 9.92,
          "y_mm": 223.652
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-13",
        "text": "I&apos;m you and you are me, and for as long as I breathe, you&apos;ll be with me.",
        "font": {
          "family": "Lucida Calligraphy",
          "size_mm": 16.241,
          "weight": 400
        },
        "position": {
          "x_mm": 0.948,
          "y_mm": 187.508
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-14",
        "text": "We love you MOM and DAD, forever.",
        "font": {
          "family": "Lucida Calligraphy",
          "size_mm": 16.658,
          "weight": 400
        },
        "position": {
          "x_mm": 8.505,
          "y_mm": 204.291
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-15",
        "text": "In loving memory, from their sons, Arbeni and Genti.",
        "font": {
          "family": "Lucida Calligraphy",
          "size_mm": 24.346,
          "weight": 400
        },
        "position": {
          "x_mm": -2.151,
          "y_mm": 247.099
        },
        "rotation": {
