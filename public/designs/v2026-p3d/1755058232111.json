      },
      {
        "id": "insc-8",
        "text": "Beloved father to Jhaqkeem,  Ryder , Kolt Harlem , Bronx  & Aniya",
        "font": {
          "family": "Garamond",
          "size_mm": 18,
          "weight": 400
        },
