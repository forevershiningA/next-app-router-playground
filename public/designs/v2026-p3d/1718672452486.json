        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-2",
        "text": "The Lord is my shepherd, I shall not want.  He lets me lie in green pastures; ",
        "font": {
          "family": "Great Vibes",
          "size_mm": 27,
          "weight": 400
        },
        "position": {
          "x_mm": -20.136,
          "y_mm": 200.112
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-3",
        "text": "He leads beside the still waters and quiet waters.  He refreshes and restores my soul;",
        "font": {
          "family": "Great Vibes",
          "size_mm": 26,
          "weight": 400
        },
        "position": {
          "x_mm": -17.933,
          "y_mm": 171.599
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-4",
        "text": "He leads me in the paths of righteousness for His name’s sake.",
        "font": {
          "family": "Great Vibes",
          "size_mm": 27,
          "weight": 400
        },
        "position": {
          "x_mm": 1.867,
