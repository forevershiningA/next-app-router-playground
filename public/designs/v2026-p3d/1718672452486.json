        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-5",
        "text": "Even though I walk through the valley of the shadow of death, I fear no evil, for You are with me.",
        "font": {
          "family": "Great Vibes",
          "size_mm": 27,
