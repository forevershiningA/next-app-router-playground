        },
        "color": "#ffffff",
        "align": "center",
        "surface": "headstone/front"
      },
      {
        "id": "insc-7",
        "text": "You prepare a table before me in the presence of my enemies.  You have anointed and refreshed my head with oil;",
        "font": {
          "family": "Great Vibes",
          "size_mm": 26,
          "weight": 400
        },
        "position": {
          "x_mm": 0.63,
