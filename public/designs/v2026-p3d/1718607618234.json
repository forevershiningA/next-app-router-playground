  "elements": {
    "inscriptions": [
      {
        "id": "insc-1",
        "text": "Psalm 23 - The Psalm of David",
        "font": {
          "family": "Garamond",
          "size_mm": 22,
          "weight": 400
        },
        "position": {
          "x_mm": -167.922,
