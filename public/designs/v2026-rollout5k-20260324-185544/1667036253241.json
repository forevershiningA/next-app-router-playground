          "z_deg": 0
        },
        "color": "#ffb35a",
        "surface": "headstone/front"
      },
      {
        "id": "insc-8",
        "text": "Nicholas Snyder",
        "font": {
          "family": "Arial",
          "size_px": 16
        },
        "position": {
          "x_px": 27.915,
          "y_px": -674.106
