          "y_px": -408.54
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffb35a",
        "surface": "headstone/front"
      },
      {
        "id": "insc-27",
        "text": "Enter a local retired engineer and a contractor with a restoration plan that",
