  "elements": {
    "inscriptions": [
      {
        "id": "insc-3",
        "text": "يَا أًيَّتُها النَّفْسُ المُطمَئِنَّة إرْجِعي إلى رَبِّكِ راضِيَةً مَرْضِيَّة",
        "font": {
          "family": "Xirwena",
          "size_px": 22
