          "size_px": 19
        },
        "position": {
          "x_px": -16,
          "y_px": -103
        },
        "rotation": {
          "z_deg": 0
        },
        "color": "#ffffff",
        "surface": "headstone/front"
      },
      {
        "id": "insc-10",
        "text": "His Angels must be rejoicing",
