        },
        "color": "#ffffff",
        "surface": "headstone/front"
      },
      {
        "id": "insc-3",
        "text": "He leads beside the still waters and quiet waters.  He refreshes and restores my soul;",
        "font": {
          "family": "Great Vibes",
          "size_px": 26
        },
        "position": {
          "x_px": 3.596,
