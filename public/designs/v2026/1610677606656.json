      },
      {
        "id": "insc-3",
        "text": "Erected by his loving wife and children.",
        "font": {
          "family": "Lucida Calligraphy",
          "size_px": 12
        },
        "position": {
          "x_px": 142.243,
          "y_px": 272.254
