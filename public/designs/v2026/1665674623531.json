        "surface": "headstone/front"
      },
      {
        "id": "insc-20",
        "text": "\"They have been an elegant ‘ceremony’ of entrance to the West Side; not just a travel",
        "font": {
          "family": "Arial",
          "size_mm": 11
        },
        "position": {
