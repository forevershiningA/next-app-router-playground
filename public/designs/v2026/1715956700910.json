      },
      {
        "id": "insc-1",
        "text": "Born May 31, 1819, in West Hills NY, and died on March 26, 1892, in Camden NJ dying at 72.",
        "font": {
          "family": "Arial",
          "size_px": 29
        },
        "position": {
          "x_px": 0,
          "y_px": 1.799
        },
