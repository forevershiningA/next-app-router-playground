<?xml version="1.0" encoding="utf-8" ?>
<data>

	<general>
		<type value="table" />
		<collection value="tomb" />
		<collection value="root-tomb" />
	</general>
	
	<edit-attributes>
		<duplicate>off</duplicate>
		<erase>off</erase>
	</edit-attributes>
	
	<informations>
		<information type="stone_area_square_meters" executable-get="stoneAreaSquareMetersInfo" />
		<information type="stone_volume_cubic_meters" executable-call="stoneVolumeCubicMetersInfo" />
	</informations>

	<properties>
		
		<section id="dimensions" label="@/ui_panel_dimensions_label">
			
			<property id="width" label="@/ui_panel_prop_width_label" type="slider">
				<value default="400" min="300" max="1200" step="1" />
			</property>
			
			<property id="height" label="@/ui_panel_prop_height_label" type="slider">
				<value default="400" min="300" max="1200" step="1" />
			</property>
			
			<property id="depth" label="@/ui_panel_prop_depth_label" type="slider">
				<value default="60" min="50" max="100" step="1" />
			</property>
			
		</section>
		
		<section id="look" label="@/ui_panel_look_label">
			
			<property id="color" label="@/ui_panel_prop_color_label" type="texture" />
			
		</section>
		
		<section id="render" label="@/ui_panel_render_label">
			
			<property id="showReflections" label="@/ui_panel_prop_show_reflections_label" type="switch" />
			
		</section>
		
	</properties>
	
	<regions>
		<region type="surface" id="inscriptions">
			<collection-filter>
				<deny value="*" />
				<allow value="table-element" />
			</collection-filter>
			<type-filter>
				<allow value="*" />
			</type-filter>
			<bounds-shape type="rectangle" x="-82" y="-130" width="164" height="260" />
			<position x="0" y="149" z="0" />
			<rotation x="90" y="0" z="0" />
		</region>
	</regions>
	
	<camera mode="autoZoomSphere" relative="true">
		<target object="this" x="0" y="200" z="0" />
		<position linear-distance="1.3" angleA="0" angleB="0" radius="600" />
		<limits>
			<linear-distance min="0.9" max="2.2" />
			<angleA min="-30" max="30" />
			<angleB min="-5" max="20" />
			<radius min="150" max="3500" />
		</limits>
	</camera>
	
	<selection type="standard" width="190" height="83" depth="309" x="0" y="0" z="0" />
	
</data>