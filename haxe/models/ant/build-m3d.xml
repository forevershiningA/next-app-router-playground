<?xml version="1.0" encoding="utf-8" ?>
<project name="build-m3d" default="build-m3d">
	<import file="config.xml"/>
	
	<property name="IGNORE_CHECKSUM" value="true"/>
	<property name="COMPILE_DEBUG" value="false"/>
	
	<target name="build-m3d">
		
		<echo>Buildind executors...</echo>
		
		<parallel threadCount="4">
			<sequential>
				<condition property="executor.file.set" else="false"><isset property="executor.file"/></condition>
				<if>
					<equals arg1="${executor.file.set}" arg2="true" />
					<then>
						<condition property="executor.out_file.var" value="${executor.out_file}" else="${executor.file}.compiled.js"><isset property="executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${executor.file}"/>
							<param name="out_file" location="${executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset1.executor.file.set" else="false"><isset property="asset1.executor.file"/></condition>
				<if>
					<equals arg1="${asset1.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset1.executor.out_file.var" value="${asset1.executor.out_file}" else="${asset1.executor.file}.compiled.js"><isset property="asset1.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset1.executor.file}"/>
							<param name="out_file" location="${asset1.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset2.executor.file.set" else="false"><isset property="asset2.executor.file"/></condition>
				<if>
					<equals arg1="${asset2.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset2.executor.out_file.var" value="${asset2.executor.out_file}" else="${asset2.executor.file}.compiled.js"><isset property="asset2.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset2.executor.file}"/>
							<param name="out_file" location="${asset2.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset3.executor.file.set" else="false"><isset property="asset3.executor.file"/></condition>
				<if>
					<equals arg1="${asset3.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset3.executor.out_file.var" value="${asset3.executor.out_file}" else="${asset3.executor.file}.compiled.js"><isset property="asset3.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset3.executor.file}"/>
							<param name="out_file" location="${asset3.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset4.executor.file.set" else="false"><isset property="asset4.executor.file"/></condition>
				<if>
					<equals arg1="${asset4.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset4.executor.out_file.var" value="${asset4.executor.out_file}" else="${asset4.executor.file}.compiled.js"><isset property="asset4.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset4.executor.file}"/>
							<param name="out_file" location="${asset4.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset5.executor.file.set" else="false"><isset property="asset5.executor.file"/></condition>
				<if>
					<equals arg1="${asset5.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset5.executor.out_file.var" value="${asset5.executor.out_file}" else="${asset5.executor.file}.compiled.js"><isset property="asset5.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset5.executor.file}"/>
							<param name="out_file" location="${asset5.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset6.executor.file.set" else="false"><isset property="asset6.executor.file"/></condition>
				<if>
					<equals arg1="${asset6.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset6.executor.out_file.var" value="${asset6.executor.out_file}" else="${asset6.executor.file}.compiled.js"><isset property="asset6.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset6.executor.file}"/>
							<param name="out_file" location="${asset6.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset7.executor.file.set" else="false"><isset property="asset7.executor.file"/></condition>
				<if>
					<equals arg1="${asset7.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset7.executor.out_file.var" value="${asset7.executor.out_file}" else="${asset7.executor.file}.compiled.js"><isset property="asset7.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset7.executor.file}"/>
							<param name="out_file" location="${asset7.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
			<sequential>
				<condition property="asset8.executor.file.set" else="false"><isset property="asset8.executor.file"/></condition>
				<if>
					<equals arg1="${asset8.executor.file.set}" arg2="true" />
					<then>
						<condition property="asset8.executor.out_file.var" value="${asset8.executor.out_file}" else="${asset8.executor.file}.compiled.js"><isset property="asset8.executor.out_file"/></condition>
						<antcall target="-build-executor">
							<param name="file" value="${asset8.executor.file}"/>
							<param name="out_file" location="${asset8.executor.out_file.var}"/>
						</antcall>
					</then>
				</if>
			</sequential>
		</parallel>
		
		<echo />
		<echo>Buildind M3D...</echo>
		
		
		<condition property="version.arg" value="-version ${version}" else=""><isset property="version"/></condition>
		<condition property="definition.file.arg" value="-definition &quot;${definition.file}&quot;" else=""><isset property="definition.file"/></condition>
		<condition property="executor.out_file.arg" value="-executor &quot;${executor.out_file.var}&quot;" else=""><isset property="executor.out_file.var"/></condition>
		<condition property="output.file.arg" value="-output &quot;${output.file}&quot;" else=""><isset property="output.file"/></condition>
		
		<condition property="asset1.executor.arg" value=" &quot;${asset1.executor.out_file.var}&quot;" else=""><isset property="asset1.executor.out_file.var"/></condition>
		<condition property="asset1.arg" value="-asset &quot;${asset1.type}&quot; &quot;${asset1.id}&quot; &quot;${asset1.file}&quot;${asset1.executor.arg}" else="">
			<and>
				<isset property="asset1.id"/>
				<isset property="asset1.type"/>
				<isset property="asset1.file"/>
				<available file="${asset1.file}"/>
			</and>
		</condition>
		<condition property="asset2.executor.arg" value=" &quot;${asset2.executor.out_file.var}&quot;" else=""><isset property="asset2.executor.out_file.var"/></condition>
		<condition property="asset2.arg" value="-asset &quot;${asset2.type}&quot; &quot;${asset2.id}&quot; &quot;${asset2.file}&quot;${asset2.executor.arg}" else="">
			<and>
				<isset property="asset2.id"/>
				<isset property="asset2.type"/>
				<isset property="asset2.file"/>
