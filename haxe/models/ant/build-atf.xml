<?xml version="1.0" encoding="utf-8" ?>
<project name="build-atf" default="build-atf">
	<import file="config.xml"/>
	
	<property name="IGNORE_CHECKSUM" value="false"/>
	
	<target name="build-atf">
		
		<checksum file="${file}" fileext=".checksum" verifyProperty="checksumOk" />
		<if>
			<or>
				<equals arg1="${checksumOk}" arg2="false" />
				<equals arg1="${IGNORE_CHECKSUM}" arg2="true" />
				<not><available file="${out_file}"/></not>
			</or>
			<then>
				<echo>Buildind ATF texture...</echo>
				<exec executable="${PNG2ATF.EXE}">
					<arg line="-q 0 -c d -i ${file} -o ${out_file}"/>
				</exec>
				<checksum file="${file}" fileext=".checksum" />
			</then>
		</if>
	</target>
	
</project>