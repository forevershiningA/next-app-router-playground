# ─────────────────────────────────────────────────────────────────────────────
# ASG inflation parameters
# CHANGE: chi0 and mu priors tightened to PC v13 posterior ± 3.5σ
#   chi0 v13 posterior: 4.726 ± 0.417  => 3.5σ window = [3.27, 6.19] -> rounded [2.80, 6.50]
#   mu   v13 posterior: 4.535 ± 0.314  => 3.5σ window = [3.44, 5.63] -> rounded [3.00, 6.10]
#   beta, Delta unchanged (posterior fills prior well: beta tail to ~0.27, Delta fills [0.1,3.0])
# WHY: 12x reduction in ASG prior volume => faster convergence, ~+2.5 in ln(Z),
#      same physical content since v13 found no posterior mass outside these bounds
# ─────────────────────────────────────────────────────────────────────────────
data.parameters['beta']  = [0.116, 0.001, 0.30,  0.0018, 1.0, 'nuisance']
data.parameters['Delta'] = [1.371, 0.10,  3.00,  0.0426, 1.0, 'nuisance']
