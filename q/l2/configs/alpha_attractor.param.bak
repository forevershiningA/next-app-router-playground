# ─────────────────────────────────────────────────────────────────────────────
data.experiments = ['alpha_bridge', 'Planck_highl_TTTEEE', 'Planck_lowl_TT', 'Planck_lowl_EE', 'Planck_lensing']

# ─────────────────────────────────────────────────────────────────────────────
# Cosmological parameters
# start  = Planck 2018 best-fit
# range  = expanded (prev run hit omega_cdm=0.15, tau=0.12 boundaries)
# step   = ~0.2 * posterior sigma
# ─────────────────────────────────────────────────────────────────────────────
data.parameters['omega_b']     = [2.2383, 2.00, 2.60, 0.003, 0.01, 'cosmo']
data.parameters['omega_cdm']   = [0.1201, 0.10, 0.20, 0.0022, 1.00, 'cosmo']
