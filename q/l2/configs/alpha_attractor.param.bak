# ─────────────────────────────────────────────────────────────────────────────
# Alpha-attractor inflation parameters
# start = alpha-chain best-fit (best_alpha.row)
# epsilon: tilt correction  n_s = 1 - 2/N + epsilon
# c:       sqrt(alpha),     r   = 12*c^2 / N^2
# Lambda:  amplitude,       A_s = Lambda * N^2 / (3*pi^2*c^2)
# ─────────────────────────────────────────────────────────────────────────────
data.parameters['epsilon'] = [2.28e-3, 1e-5, 1e-2, 2.3e-4, 1.0, 'nuisance']
data.parameters['c']       = [0.796,   0.10, 3.00, 0.040,  1.0, 'nuisance']
data.parameters['Lambda']  = [6.566e-11, 1e-11, 3e-10, 2.3e-13, 1.0, 'nuisance']

